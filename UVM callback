`include "uvm_macros.svh"
import uvm_pkg::*;

typedef enum{DATA_1, DATA_2, EXT_DATA_1, EXT_DATA_2}pkt_type;

pkt_type pkt;


class driver_cb extends uvm_callback;
  `uvm_object_utils(driver_cb)
  
  function new(string name = "driver_cb");
    super.new(name);
  endfunction: new

  
  virtual task modify_pkt();
    `uvm_info(get_type_name(), "Inside the modify_pkt task of driver_cb", UVM_LOW) 

  endtask: modify_pkt
  
endclass: driver_cb

class derived_cb extends driver_cb;
  `uvm_object_utils(derived_cb)
  
  function new(string name = "derived_cb");
    super.new(name);
  endfunction: new

  
  task modify_pkt();
    `uvm_info(get_type_name(), "Inside the modify_pkt task of derived_cb", UVM_LOW) 

    std::randomize(pkt) with {pkt inside {EXT_DATA_1, EXT_DATA_2};};
  endtask: modify_pkt
  
endclass: derived_cb

class my_driver extends uvm_driver;
  `uvm_component_utils(my_driver)
  
  function new(string name = "my_driver", uvm_component parent= null);
    super.new(name, parent);
  endfunction: new

  function void build_phase(uvm_phase phase);
     super.build_phase(phase);   
    `uvm_info(get_type_name(), "Inside the build_phase of my_driver", UVM_LOW) 

  endfunction: build_phase
  
  task run_phase(uvm_phase phase);
    `uvm_info(get_type_name(), "Inside the run_phase of my_driver", UVM_LOW) 
    drive();
    
    // Creating Hook
    `uvm_do_callbacks(my_driver, driver_cb, modify_pkt())
    // 1st argument tells where the hook is present(my_driver class)
    // 2nd argument tells call back type(driver_cb class)
    // 3rd argument tells the callback method

    `uvm_info(get_type_name(), $psprintf("Packet = %p", pkt), UVM_LOW) 

  endtask: run_phase
  
  task drive();
    `uvm_info(get_type_name(), "Inside the drive task of my_driver", UVM_LOW) 

    std::randomize(pkt) with {pkt == DATA_1;};
  endtask: drive
  
endclass: my_driver


class my_env extends uvm_env;
  `uvm_component_utils(my_env)
  
  my_driver drv;
  
  function new(string name = "my_env", uvm_component parent= null);
    super.new(name, parent);
  endfunction: new

  function void build_phase(uvm_phase phase);
     super.build_phase(phase);   
    `uvm_info(get_type_name(), "Inside the build_phase of my_env", UVM_LOW) 
    drv = my_driver :: type_id :: create("drv", this);
  endfunction: build_phase
  
  task run_phase(uvm_phase phase);
    `uvm_info(get_type_name(), "Inside the run_phase of my_env", UVM_LOW) 
   
  endtask: run_phase
  
endclass: my_env


class base_test extends uvm_test;
  `uvm_component_utils(base_test)
  
  my_env env;
  
  function new(string name = "base_test", uvm_component parent= null);
    super.new(name, parent);
  endfunction: new

  function void build_phase(uvm_phase phase);
     super.build_phase(phase);   
    `uvm_info(get_type_name(), "Inside the build_phase of base_test", UVM_LOW) 
    env = my_env :: type_id :: create("env", this);
  endfunction: build_phase
  
  task run_phase(uvm_phase phase);
    `uvm_info(get_type_name(), "Inside the run_phase of base_test", UVM_LOW) 
   
  endtask: run_phase
  
endclass: base_test


class test_cb extends base_test;
  `uvm_component_utils(test_cb)
  
  derived_cb dcb;
  
  function new(string name = "test_cb", uvm_component parent= null);
    super.new(name, parent);
  endfunction: new

  function void build_phase(uvm_phase phase);
     super.build_phase(phase);   
    `uvm_info(get_type_name(), "Inside the build_phase of test_cb", UVM_LOW) 
    dcb = derived_cb :: type_id ::create("dcb");
    
    uvm_callbacks #(my_driver, driver_cb) :: add(env.drv, dcb);
    // my_driver: component where the hook is present
    // driver_cb: main callback class
    // add is a static method which is present in uvm_callbacks class
    // provide the first argument with the path where driver is present, inside "add" method 
    // and second argument should be the class handle where the implementation of call back method is present

//     uvm_callbacks #(my_driver, driver_cb) :: delete(env.drv, dcb);

  endfunction: build_phase
  
  
  task run_phase(uvm_phase phase);
    `uvm_info(get_type_name(), "Inside the run_phase of my_test", UVM_LOW) 
   
  endtask: run_phase
  
endclass: test_cb


module uvm_callback_top;
  
  
  initial
    begin
//       run_test("base_test");
      run_test("test_cb");
    end
endmodule: uvm_callback_top
